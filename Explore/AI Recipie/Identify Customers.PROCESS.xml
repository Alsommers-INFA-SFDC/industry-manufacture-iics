                     <expression language="XQuery">let $allRecords := 
  (
    $temp.tmp_Entity1_Response//records,
    $temp.tmp_Entity2_Response//records
  )
(:Logic to get top 5 records based on match score:)
let $topFive := 
  for $r in $allRecords
  let $scoreText := normalize-space(string($r/score))
  let $score := 
    if (matches($scoreText, '^\d+$')) 
    then xs:integer($scoreText) 
    else 0
  order by $score descending
  return $r

return 
if (empty($topFive)) then
    'No Records Found'
  else
    &lt;root&gt;{
      for $rec in $topFive[position() &lt;= $input.NumberOfRecordsReturn ]
      return
        element records {
          for $child in $rec/*
          where local-name($child) != 'score'
          return $child
        }}&lt;/root&gt;</expression>
