                        <operation source="formula" to="temp.tmp_Entity1_Response">
                           <expression language="XQuery">let $source:=  $output.Search_Match_API_Response 
(: Helper to check if full local-name path is excluded :)
let $nameMapXML := $temp.tmp_Entity1_map_fields 
  
let $excludeXML := $temp.tmp_Entity1_exclude_fields 
(: Helper to check if full local-name path is excluded :)
let $isExcluded := function($path) {
  some $ex in $excludeXML/item satisfies $ex = $path
}
(: Helper to get mapped name or fallback to local-name :)
let $getName := function($path) {
  let $entry := $nameMapXML/mapEntry[@key = $path]
  return if (exists($entry)) then string($entry) else fn:tokenize($path, '/')[last()]
}
(: Start processing root element children :)
return
if ( $source//totalRecords/text() = 0) then 'No Records'
else
&lt;root&gt;{
  for $records in $source//records
  return
    element { "records" } {
      for $child1 in $records/*
      let $name1 := local-name($child1)
      let $path1 := concat('/root/searchResult/records/', $name1)
      where not($isExcluded($path1))
      return
        element { $getName($path1) } {
          if ($name1 = "data") then
            (
              for $child2 in $child1/*
              let $name2 := local-name($child2)
              let $path2 := concat($path1, '/', $name2)
              where not($isExcluded($path2))
              return
                element { $getName($path2) } {
                  if ($child2/*) then
                    (
                      for $child3 in $child2/*
                      let $name3 := local-name($child3)
                      let $path3 := concat($path2, '/', $name3)
                      where not($isExcluded($path3))
                      return
                        if ($child3/*) then
                          element { $getName($path3) } {
                            for $child4 in $child3/*
                            let $name4 := local-name($child4)
                            let $path4 := concat($path3, '/', $name4)
                            where not($isExcluded($path4))
                            return 
                              if (not($isExcluded($path4))) then
                                element { $getName($path4) } { $child4/node() }
                              else ()
                          }
                        else
                          element { $getName($path3) } { data($child3) }
                    )
                  else
                    data($child2)
                }
            )
          else
            $child1/node()
        },
      (: Prepare businessId element if not excluded :)
      let $businessIdName := $getName("businessId")
      where not($isExcluded("/root/searchResult/records/_meta/businessId"))
      return element { $businessIdName } { $records/_meta/businessId/text() },

      (: entityType inside records :)
      let $entityTypeName := $getName("entityType")
      let $entityTypeValue := 'organization'
      where not($isExcluded("/root/searchResult/records/_meta/entityType"))
      return 
        if (exists($entityTypeValue)) then
          element { $entityTypeName } { $entityTypeValue }
        else ()
    }
}&lt;/root&gt;
</expression>
