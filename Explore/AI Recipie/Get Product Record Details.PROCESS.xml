                  <operation source="formula" to="temp.tmp_ExcludeFields">
                     <expression language="XQuery">$temp.tmp_Config_Info//Exclusions/entity1/exclude</expression>
                  </operation>
                  <operation source="formula" to="output.Product_details_Response">
                     <expression language="XQuery">let $ItemDetails_response := $output.MDM_API_Response   

let $nameMapXML := $temp.tmp_MapFields 

let $excludeXML := $temp.tmp_ExcludeFields 

(: Helper to check if full local-name path is excluded :)
(: Inline approach checking against constructed paths :)
let $isExcluded := function($path) {
  some $ex in $excludeXML/item satisfies $ex = $path
}

(: Helper to get mapped name or fallback to local-name :)
let $getName := function($path) {
  let $entry := $nameMapXML/mapEntry[@key = $path]
  return if (exists($entry)) then string($entry) else fn:tokenize($path, '/')[last()]
}

(: Prepare businessId element if not excluded :)
let $bizIdPath := "/root/_meta/businessId"
let $businessIdElem :=
  if (not($isExcluded($bizIdPath))) then
    element { $getName("businessId") } { $ItemDetails_response//_meta/businessId/text() }
  else ()

(: Start processing root element children :)
return
&lt;root&gt;{(
  for $child1 in $ItemDetails_response/*
  let $name1 := local-name($child1)
  let $path1 := concat('/root/', $name1)
  where not($isExcluded($path1))
  return
    element { $getName($path1) } {
      if ($child1/node()[self::element()]) then
        (
          for $child2 in $child1/*
          let $name2 := local-name($child2)
          let $path2 := concat($path1, '/', $name2)
          where not($isExcluded($path2))
          return
            element { $getName($path2) } {
              if ($child2/node()[self::element()]) then
                (
                  for $child3 in $child2/*
                  let $name3 := local-name($child3)
                  let $path3 := concat($path2, '/', $name3)
                  where not($isExcluded($path3))
                  return
                    if ($child3/node()[self::element()]) then
                      (
                        for $child4 in $child3/*
                        let $name4 := local-name($child4)
                        let $path4 := concat($path3, '/', $name4)
                        where not($isExcluded($path4))
                        return element { $getName($path4) } { $child4/node() }
                      )
                    else
                      element { $getName($path3) } { data($child3) }
                )
              else
                data($child2)
            }
        )
      else
        data($child1)
    }),
    $businessIdElem
}&lt;/root&gt;

</expression>
