               <eventContainer id="memiycta">
                  <service id="melblerm">
                     <title>Related Entites API</title>
                     <serviceName>MDMConnection:Related_Entites_API</serviceName>
                     <serviceGUID>4drsl65Bm5AkuewzHRbiCq</serviceGUID>
                     <serviceInput>
                        <parameter name="MDM_ID" source="field" updatable="true">input.MDM_ID</parameter>
                        <parameter name="Body_Request" source="field" updatable="true">temp.tmp_Search_Criteria</parameter>
                        <parameter name="Session_ID" source="field" updatable="true">output.Session_ID</parameter>
                     </serviceInput>
                  </service>
                  <flow id="memiyctc">
                     <assignment id="meqqioql">
                        <title>Configure Relationship Response</title>
                        <operation source="formula" to="temp.tmp_MapFields">
                           <expression language="XQuery">$temp.tmp_Config_Info//relationshiplabel/nameMap</expression>
                        </operation>
                        <operation source="formula" to="temp.tmp_ExcludeFields">
                           <expression language="XQuery">$temp.tmp_Config_Info//Exclusions/relations/exclude</expression>
                        </operation>
                        <operation source="formula" to="temp.tmp_relationships">
                           <expression language="XQuery">$temp.tmp_Config_Info//relationships/relMap</expression>
                        </operation>
                        <operation source="formula" to="output.Relationship_Response">
                           <expression language="XQuery">let $RelatedEntites_response := $output.Related_Entites_Response 

let $nameMapXML := $temp.tmp_MapFields 

let $excludeXML := $temp.tmp_ExcludeFields 

(: Relationship code to name mapping :)
let $relationshipMap := $temp.tmp_relationships 

(: Helper to test exclusion by full XPath :)
let $isExcluded := function($path as xs:string) as xs:boolean {
  some $ex in $excludeXML/item satisfies $ex = $path
}

(: Helper to get mapped name by full XPath key or fallback :)
let $getName := function($path as xs:string) as xs:string {
  let $entry := $nameMapXML/mapEntry[@key = $path]
  return if (exists($entry)) then string($entry) else fn:tokenize($path, '/')[last()]
}

(: Helper to get mapped relationship name dynamically :)
let $getMappedRel := function($relcode as xs:string) as xs:string {
  let $entry := $relationshipMap/map[@from = $relcode]/@to
  return if (exists($entry)) then string($entry) else $relcode
}
(: Start processing root element children :)
return
if ( $RelatedEntites_response//resultsInPage/text() = 0) then 'No Related Records'
else
&lt;root&gt;{
  for $content in $RelatedEntites_response/content
  let $path1 := '/root/content'
  where not($isExcluded($path1))
  return element { $getName($path1) } {
    let $relPath := concat($path1, '/relation/_meta/relationship')
    let $rel := $content/relation/_meta/relationship/string()
    let $mappedRel := $getMappedRel($rel)
    return (
      element { $getName($relPath) } { $mappedRel },
      let $targetEntityPath := concat($path1, '/targetEntity')
      return
        if (not($isExcluded($targetEntityPath))) then
          element { $getName($targetEntityPath) } {
            for $child1 in $content/targetEntity/*
            let $path2 := concat($targetEntityPath, '/', local-name($child1))
            where not($isExcluded($path2))
            return
              if ($child1/node()[self::element()]) then
                element { $getName($path2) } {
                  for $child2 in $child1/*
                  let $path3 := concat($path2, '/', local-name($child2))
                  where not($isExcluded($path3))
                  return
                    if ($child2/node()[self::element()]) then
                      element { $getName($path3) } {
                        for $child3 in $child2/*
                        let $path4 := concat($path3, '/', local-name($child3))
                        where not($isExcluded($path4))
                        return element { $getName($path4) } { $child3/node() }
                      }
                    else element { $getName($path3) } { data($child2) }
                }
              else element { $getName($path2) } { data($child1) },
            (: Add businessId here from targetEntity/_meta/businessId :)
            element { $getName(concat($targetEntityPath, '/_meta/businessId')) } {
              $content/targetEntity/_meta/businessId/text()
            },
            (: Add businessEntity here from targetEntity/_meta/businessEntity :)
            element { $getName(concat($targetEntityPath, '/_meta/businessEntity')) } {
              substring-after($content/targetEntity/_meta/businessEntity/text(),'.')
            }
          }
        else ()
    )
  }
}
&lt;/root&gt;
</expression>
                        </operation>
